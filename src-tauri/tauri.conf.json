{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScaleBridge",
  "version": "0.1.0",
  "identifier": "com.ph0ryn.scalebridge",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ScaleBridge",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "create": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns"],
    "targets": ["app", "dmg"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
